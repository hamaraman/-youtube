# ============================================
# MyTube 필수 환경변수 (이 파일을 .env로 복사 후 값을 채우세요)
# cp .env.example .env
# ============================================

# [필수] 데이터베이스
DB_URL=jdbc:mariadb://localhost:3306/mytube
DB_USERNAME=root
DB_PASSWORD=your_db_password

# [필수] JWT 시크릿 (32자 이상의 안전한 랜덤 문자열)
JWT_SECRET=your_jwt_secret_32chars_or_more!!

# [필수] 관리자 비밀번호 (강력한 비밀번호 사용)
ADMIN_PASSWORD=your_strong_admin_password

# [선택] MinIO 오브젝트 스토리지
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key
MINIO_BUCKET=mytube-videos
MINIO_PUBLIC_URL=

# [선택] Gmail SMTP (비밀번호 재설정 기능)
MAIL_USERNAME=your_gmail@gmail.com
MAIL_PASSWORD=your_gmail_app_password

# [선택] 허용 도메인 (기본값: localhost)
ALLOWED_ORIGINS=http://localhost:8080
APP_BASE_URL=http://localhost:8080
