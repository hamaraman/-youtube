# 서버 주소 (배포 서버의 공개 URL)
SERVER_URL=https://mytube.it.com

# 서버 application.properties 의 worker.token 과 반드시 동일하게
WORKER_TOKEN=change-me-to-a-long-random-secret

# 워커 식별자 (생략 시 PC 호스트네임 사용)
# WORKER_ID=home-rtx

# Cloudflare R2 (서버와 동일한 값)
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ffmpeg / ffprobe 경로 (PATH에 있으면 그대로 두면 됨)
FFMPEG=ffmpeg
FFPROBE=ffprobe

# 하드웨어 가속: nvenc(NVIDIA) / qsv(Intel) / amf(AMD) / none(CPU)
HW_ACCEL=nvenc

# 작업이 없을 때 폴링 간격(초)
POLL_INTERVAL=10

# 변환 임시 작업 폴더 (생략 시 시스템 임시폴더)
# WORK_DIR=D:\transcode_tmp
